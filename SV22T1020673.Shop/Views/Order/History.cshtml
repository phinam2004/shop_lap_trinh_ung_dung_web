@model SV22T1020673.Models.Common.PagedResult<SV22T1020673.Models.Sales.OrderSearchInfo>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="hero-section mb-0">
    <div class="container d-flex align-items-center">
        <div class="bg-white rounded-circle p-3 shadow-sm me-4">
            <i class="fa-solid fa-shopping-bag fs-1 text-primary"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1">Đơn hàng của tôi</h1>
            <p class="text-muted mb-0">Theo dõi và quản lý lịch sử mua hàng của bạn.</p>
        </div>
    </div>
</div>

<div class="container" style="margin-top: -3rem;">
    <div class="row">
        <div class="col-lg-4 mb-4">
            @await Html.PartialAsync("_AccountSidebar")
        </div>

        <div class="col-lg-8">
            <div class="card p-4 fade-in border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                @if (Model.DataItems != null && Model.DataItems.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Mã ĐH</th>
                                    <th class="py-3 border-0">Thời gian đặt</th>
                                    <th class="py-3 border-0 text-center">Trạng thái</th>
                                    <th class="pe-4 py-3 border-0 text-end">Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.DataItems)
                                {
                                    <tr>
                                        <td class="ps-4 py-4 fw-bold text-primary">#@order.OrderID</td>
                                        <td class="text-muted small">@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-center">
                                            @{
                                                string badgeClass = order.Status switch
                                                {
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.New => "bg-primary-subtle text-primary",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Accepted => "bg-info-subtle text-info",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Shipping => "bg-warning-subtle text-warning",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Completed => "bg-success-subtle text-success",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Cancelled => "bg-danger-subtle text-danger",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Rejected => "bg-danger-subtle text-danger",
                                                    _ => "bg-secondary-subtle text-secondary"
                                                };
                                                string statusText = order.Status switch
                                                {
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.New => "Mới",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Accepted => "Đã duyệt",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Shipping => "Đang giao",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Completed => "Thành công",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Cancelled => "Đã hủy",
                                                    SV22T1020673.Models.Sales.OrderStatusEnum.Rejected => "Bị từ chối",
                                                    _ => "Không xác định"
                                                };
                                            }
                                            <span class="badge rounded-pill @badgeClass px-3 py-2 fw-medium" style="font-size: 0.75rem;">@statusText</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a asp-action="Details" asp-route-id="@order.OrderID" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                Xem
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.PageCount > 1)
                    {
                        <div class="card-footer bg-white border-0 py-4">
                            <nav>
                                <ul class="pagination justify-content-center mb-0">
                                    @for (int i = 1; i <= Model.PageCount; i++)
                                    {
                                        <li class="page-item @(i == Model.Page ? "active" : "")">
                                            <a class="page-link border-0 shadow-sm mx-1 rounded-3" href="@Url.Action("History", new { page = i })">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        </div>
                    }
                }
                else
                {
                    <div class="p-5 text-center">
                        <div class="mb-4">
                            <i class="fa-solid fa-receipt text-muted opacity-25" style="font-size: 5rem;"></i>
                        </div>
                        <h4 class="fw-bold">Bạn chưa có đơn hàng nào</h4>
                        <p class="text-muted mb-4">Đơn hàng của bạn sẽ xuất hiện tại đây sau khi bạn đặt hàng.</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2">Bắt đầu mua sắm</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-subtle { background-color: rgba(11, 116, 229, 0.1); }
    .bg-info-subtle { background-color: rgba(6, 182, 212, 0.1); }
    .bg-warning-subtle { background-color: rgba(245, 158, 11, 0.1); }
    .bg-success-subtle { background-color: rgba(34, 197, 94, 0.1); }
    .bg-danger-subtle { background-color: rgba(255, 66, 78, 0.1); }
    .page-link { color: var(--sv-blue); }
    .active .page-link { background-color: var(--sv-blue) !important; color: white !important; }
</style>
