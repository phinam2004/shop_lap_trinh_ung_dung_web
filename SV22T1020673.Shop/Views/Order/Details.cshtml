@model SV22T1020673.Models.Sales.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderID;
    var details = ViewBag.Details as List<SV22T1020673.Models.Sales.OrderDetailViewInfo>;
    decimal total = details?.Sum(x => x.TotalPrice) ?? 0;
}

<div class="hero-section mb-0">
    <div class="container d-flex align-items-center">
        <div class="bg-white rounded-circle p-3 shadow-sm me-4">
            <i class="fa-solid fa-file-invoice fs-1 text-primary"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1">Chi tiết đơn hàng #@Model.OrderID</h1>
            <p class="text-muted mb-0">Xem thông tin chi tiết và hành trình đơn hàng của bạn.</p>
        </div>
    </div>
</div>

<div class="container" style="margin-top: -3rem;">
    <div class="row">
        <div class="col-lg-3 mb-4">
            @await Html.PartialAsync("_AccountSidebar")
        </div>

        <div class="col-lg-9">
            <div class="animate-fade-in">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <a asp-action="History" class="btn btn-link text-decoration-none p-0">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại lịch sử
                    </a>
                    <div class="text-end">
                        @{
                            string statusClass = Model.Status switch {
                                SV22T1020673.Models.Sales.OrderStatusEnum.New => "bg-primary-subtle text-primary",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Accepted => "bg-info-subtle text-info",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Shipping => "bg-warning-subtle text-warning",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Completed => "bg-success-subtle text-success",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Cancelled => "bg-danger-subtle text-danger",
                                _ => "bg-secondary-subtle text-secondary"
                            };
                            string statusName = Model.Status switch {
                                SV22T1020673.Models.Sales.OrderStatusEnum.New => "Vừa khởi tạo",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Accepted => "Đã duyệt",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Shipping => "Đang giao hàng",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Completed => "Thành công",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Cancelled => "Đã hủy",
                                SV22T1020673.Models.Sales.OrderStatusEnum.Rejected => "Bị từ chối",
                                _ => "Không xác định"
                            };
                        }
                        <span class="badge rounded-pill @statusClass px-4 py-2 fw-medium">@statusName</span>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-xl-8">
                        <!-- Delivery Information -->
                        <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0 text-uppercase small text-muted"><i class="fa-solid fa-location-dot me-2 text-primary"></i>Thông tin nhận hàng</h6>
                                @if (Model.Status == SV22T1020673.Models.Sales.OrderStatusEnum.New || Model.Status == SV22T1020673.Models.Sales.OrderStatusEnum.Accepted)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1" data-bs-toggle="modal" data-bs-target="#editDeliveryModal">
                                        <i class="fa-solid fa-pen-to-square me-1"></i>Sửa
                                    </button>
                                }
                            </div>
                            <div class="row">
                                <div class="col-sm-6">
                                    <p class="mb-1 text-muted small">Người nhận</p>
                                    <p class="fw-bold mb-3">@Context.Session.GetString("CustomerName")</p>
                                    <p class="mb-1 text-muted small">Tỉnh/Thành phố</p>
                                    <p class="fw-bold mb-3">@(string.IsNullOrEmpty(Model.DeliveryProvince) ? "(Chưa chọn)" : Model.DeliveryProvince)</p>
                                </div>
                                <div class="col-sm-6">
                                    <p class="mb-1 text-muted small">Số điện thoại</p>
                                    <p class="fw-bold mb-3">@((Model as SV22T1020673.Models.Sales.OrderViewInfo)?.CustomerPhone)</p>
                                    <p class="mb-1 text-muted small">Địa chỉ chi tiết</p>
                                    <p class="fw-bold mb-0">@(string.IsNullOrEmpty(Model.DeliveryAddress) ? "(Chưa cập nhật)" : Model.DeliveryAddress)</p>
                                </div>
                            </div>
</div>

                        <!-- Items List -->
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                            <div class="card-header bg-white border-0 py-3">
                                <h6 class="fw-bold mb-0 text-uppercase small text-muted">Danh sách sản phẩm</h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="ps-4 border-0 small">Sản phẩm</th>
                                            <th class="text-center border-0 small">SL</th>
                                            <th class="pe-4 text-end border-0 small">Thành tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (details != null) {
                                            foreach (var item in details) {
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="d-flex align-items-center">
                                                            <img src="@(string.IsNullOrEmpty(item.Photo) ? WebConfig.ImageServerUrl + "/images/products/nophoto.png" : $"{WebConfig.ImageServerUrl}/images/products/{item.Photo}")" 
                                                                 class="rounded me-3 border" style="width: 45px; height: 45px; object-fit: cover;">
                                                            <div>
                                                                <h6 class="fw-bold mb-0 small">@item.ProductName</h6>
                                                                <small class="text-muted">@item.SalePrice.ToString("N0") đ</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td class="text-center small">x@(item.Quantity)</td>
                                                    <td class="pe-4 text-end fw-bold small">@item.TotalPrice.ToString("N0") đ</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                    <tfoot class="bg-light">
                                        <tr>
                                            <td colspan="2" class="ps-4 text-end fw-bold py-3 small">Tổng cộng:</td>
                                            <td class="pe-4 text-end text-primary fw-bold py-3">@total.ToString("N0") đ</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-4">
                        <!-- Tracking Timeline -->
                        <div class="card border-0 shadow-sm p-4 rounded-4 mb-4">
                            <h6 class="fw-bold mb-4 text-uppercase small text-muted"><i class="fa-solid fa-truck-ramp-box me-2 text-primary"></i>Hành trình đơn hàng</h6>
                            <div class="sv-timeline px-2">
                                <!-- Step 1: Order Placed -->
                                <div class="sv-timeline-item active">
                                    <div class="sv-timeline-icon">
                                        <i class="fa-solid fa-cart-shopping"></i>
                                    </div>
                                    <div class="sv-timeline-content">
                                        <h6 class="fw-bold mb-0 small">Đặt hàng thành công</h6>
                                        <p class="text-muted mb-1" style="font-size: 0.75rem;">Đơn hàng đã được ghi nhận vào hệ thống</p>
                                        <small class="text-primary fw-medium d-block" style="font-size: 0.7rem;"><i class="fa-regular fa-clock me-1"></i>@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                </div>

                                <!-- Step 2: Approved -->
                                <div class="sv-timeline-item @(Model.AcceptTime != null ? "active" : "")">
                                    <div class="sv-timeline-icon">
                                        <i class="fa-solid fa-clipboard-check"></i>
                                    </div>
                                    <div class="sv-timeline-content">
                                        <h6 class="fw-bold mb-0 small">Vừa xác nhận</h6>
                                        <p class="text-muted mb-1" style="font-size: 0.75rem;">Người bán đã xác nhận đơn hàng</p>
                                        @if (Model.AcceptTime != null) {
                                            <small class="text-primary fw-medium d-block" style="font-size: 0.7rem;"><i class="fa-regular fa-clock me-1"></i>@Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")</small>
                                        }
                                    </div>
                                </div>

                                <!-- Step 3: Shipping -->
                                <div class="sv-timeline-item @(Model.ShippedTime != null ? "active" : "")">
                                    <div class="sv-timeline-icon">
                                        <i class="fa-solid fa-truck-fast"></i>
                                    </div>
                                    <div class="sv-timeline-content">
                                        <h6 class="fw-bold mb-0 small">Đang giao hàng</h6>
                                        <p class="text-muted mb-1" style="font-size: 0.75rem;">Đơn hàng đang trên đường đến bạn</p>
                                        @if (Model.ShippedTime != null) {
                                            <small class="text-primary fw-medium d-block" style="font-size: 0.7rem;"><i class="fa-regular fa-clock me-1"></i>@Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm")</small>
                                        }
                                    </div>
                                </div>

                                <!-- Step 4: Finished -->
                                <div class="sv-timeline-item @(Model.FinishedTime != null ? "active last-" + Model.Status.ToString().ToLower() : "")">
                                    <div class="sv-timeline-icon">
                                        @if (Model.Status == SV22T1020673.Models.Sales.OrderStatusEnum.Completed) {
                                            <i class="fa-solid fa-flag-checkered"></i>
                                        } else if (Model.Status == SV22T1020673.Models.Sales.OrderStatusEnum.Cancelled || Model.Status == SV22T1020673.Models.Sales.OrderStatusEnum.Rejected) {
                                            <i class="fa-solid fa-ban"></i>
                                        } else {
                                            <i class="fa-solid fa-circle-dot"></i>
                                        }
                                    </div>
                                    <div class="sv-timeline-content">
                                        <h6 class="fw-bold mb-0 small">@statusName</h6>
                                        <p class="text-muted mb-1" style="font-size: 0.75rem;">Đơn hàng đã kết thúc hành trình</p>
                                        @if (Model.FinishedTime != null) {
                                            <small class="fw-medium d-block" style="font-size: 0.7rem;"><i class="fa-regular fa-clock me-1"></i>@Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")</small>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card p-4 border-0 shadow-sm rounded-4 bg-primary text-white">
                            <p class="small mb-3 opacity-75">Cảm ơn bạn đã tin tưởng mua sắm tại SVShop. Nếu có bất kỳ thắc mắc nào, hãy liên hệ hỗ trợ.</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-sm w-100 rounded-pill fw-bold text-primary py-2 text-uppercase" style="font-size: 0.7rem;">
                                Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Delivery Modal -->
<div class="modal fade" id="editDeliveryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold mb-0">Cập nhật thông tin nhận hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editDeliveryForm">
                <div class="modal-body py-4">
                    <input type="hidden" name="id" value="@Model.OrderID" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Địa chỉ chi tiết</label>
                        <input type="text" name="deliveryAddress" class="form-control rounded-3" value="@Model.DeliveryAddress" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Tỉnh/Thành phố</label>
                        <select name="deliveryProvince" class="form-select rounded-3" required>
                            <option value="">-- Chọn Tỉnh/Thành phố --</option>
                            @if (ViewBag.Provinces != null)
                            {
                                foreach (var p in ViewBag.Provinces as List<SV22T1020673.Models.DataDictionary.Province>)
                                {
                                    <option value="@p.ProvinceName" selected="@(p.ProvinceName == Model.DeliveryProvince)">@p.ProvinceName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-0">
                        <label class="form-label small fw-bold text-muted">Số điện thoại liên hệ</label>
                        <input type="text" name="deliveryPhone" class="form-control rounded-3" value="@((Model as SV22T1020673.Models.Sales.OrderViewInfo)?.CustomerPhone)" required>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-link text-muted text-decoration-none small" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" id="btnUpdateDelivery">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-primary-subtle { background-color: rgba(11, 116, 229, 0.1); }
    .bg-info-subtle { background-color: rgba(6, 182, 212, 0.1); }
    .bg-warning-subtle { background-color: rgba(245, 158, 11, 0.1); }
    .bg-success-subtle { background-color: rgba(34, 197, 94, 0.1); }
    .bg-danger-subtle { background-color: rgba(255, 66, 78, 0.1); }
    
    .timeline::before {
        content: ''; position: absolute; left: 0; top: 5px; bottom: 5px;
        width: 1px; background: #e2e8f0;
    }
        .timeline-dot {
        position: absolute; left: -5px; top: 5px; width: 11px; height: 11px;
        border-radius: 50%; border: 2px solid white; box-shadow: 0 0 0 1px rgba(0,0,0,0.05);
    }

    /* Modern Vertical Timeline */
    .sv-timeline {
        position: relative;
    }
    .sv-timeline::before {
        content: '';
        position: absolute;
        left: 17px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #f1f5f9;
        z-index: 1;
    }
    .sv-timeline-item {
        position: relative;
        padding-left: 50px;
        padding-bottom: 25px;
        z-index: 2;
    }
    .sv-timeline-item:last-child {
        padding-bottom: 0;
    }
    .sv-timeline-icon {
        position: absolute;
        left: 0;
        top: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #f8fafc;
        border: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        box-shadow: 0 0 0 4px #fff;
    }
    .sv-timeline-item.active .sv-timeline-icon {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
        box-shadow: 0 0 15px rgba(13, 110, 253, 0.2), 0 0 0 4px #fff;
    }
    
    /* Finished icons colors */
    .sv-timeline-item.active.last-completed .sv-timeline-icon {
        background: #198754;
        border-color: #198754;
        box-shadow: 0 0 15px rgba(25, 135, 84, 0.2), 0 0 0 4px #fff;
    }
    .sv-timeline-item.active.last-cancelled .sv-timeline-icon,
    .sv-timeline-item.active.last-rejected .sv-timeline-icon {
        background: #dc3545;
        border-color: #dc3545;
        box-shadow: 0 0 15px rgba(220, 53, 69, 0.2), 0 0 0 4px #fff;
    }
    
    .sv-timeline-content {
        padding-top: 5px;
    }
    
    /* Progress Line logic */
    .sv-timeline-item.active::after {
        content: '';
        position: absolute;
        left: 17px;
        top: 36px;
        bottom: 0;
        width: 2px;
        background: #0d6efd;
        z-index: 1;
        transition: all 0.5s ease;
    }
    .sv-timeline-item:last-child.active::after {
        display: none;
    }
    .sv-timeline-item.active.last-completed::after,
    .sv-timeline-item.active.last-cancelled::after,
    .sv-timeline-item.active.last-rejected::after {
        display: none;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#editDeliveryForm').submit(function(e) {
                e.preventDefault();
                const btn = $('#btnUpdateDelivery');
                btn.prop('disabled', true).text('Đang cập nhật...');

                $.post('/Order/UpdateDelivery', $(this).serialize(), function(res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message || 'Có lỗi xảy ra khi cập nhật.');
                        btn.prop('disabled', false).text('Cập nhật');
                    }
                });
            });
        });
    </script>
}
