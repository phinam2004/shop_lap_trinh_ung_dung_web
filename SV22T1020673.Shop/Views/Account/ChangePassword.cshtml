@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="hero-section mb-0">
    <div class="container d-flex align-items-center">
        <div class="bg-white rounded-circle p-3 shadow-sm me-4">
            <i class="fa-solid fa-shield-halved fs-1 text-primary"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1">Bảo mật tài khoản</h1>
            <p class="text-muted mb-0">Đổi mật khẩu định kỳ để bảo vệ tài khoản của bạn.</p>
        </div>
    </div>
</div>

<div class="container" style="margin-top: -3rem;">
    <div class="row">
        <div class="col-lg-4 mb-4">
            @await Html.PartialAsync("_AccountSidebar")
        </div>

        <div class="col-lg-8">
            <div class="card p-4 p-md-5 fade-in shadow-lg">
                <h5 class="fw-bold mb-4">Đổi mật khẩu mới</h5>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4 fade show" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i>@ViewBag.Message
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 shadow-sm mb-4 fade show" role="alert">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    <div class="mb-4">
                        <label for="oldPassword" class="form-label fw-bold small">Mật khẩu hiện tại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="fa-solid fa-unlock-keyhole"></i>
                            </span>
                            <input type="password" class="form-control border-start-0" id="oldPassword" name="oldPassword" placeholder="Nhập mật khẩu cũ" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="newPassword" class="form-label fw-bold small">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input type="password" class="form-control border-start-0" id="newPassword" name="newPassword" placeholder="Tối thiểu 6 ký tự" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label for="confirmPassword" class="form-label fw-bold small">Xác nhận mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="fa-solid fa-check-double"></i>
                            </span>
                            <input type="password" class="form-control border-start-0" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required>
                        </div>
                    </div>

                    <div class="d-flex gap-3 pt-3 border-top">
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">
                            <i class="fa-solid fa-key me-2"></i>Cập nhật mật khẩu
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary px-4">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
