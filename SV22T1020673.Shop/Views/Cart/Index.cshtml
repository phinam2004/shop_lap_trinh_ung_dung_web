@model List<SV22T1020673.Shop.Controllers.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="hero-section mb-5 py-5">
    <div class="container text-center">
        <h1 class="fw-bold mb-2">Giỏ hàng của bạn</h1>
        <p class="text-muted">Kiểm tra lại các sản phẩm và tiến hành thanh toán.</p>
    </div>
</div>

<div class="container" style="margin-top: -4rem;">
    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-4">
            <!-- Cart Items List -->
            <div class="col-lg-8">
                <div class="card p-4 border-0 shadow-sm fade-in rounded-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Sản phẩm (@Model.Sum(i => i.Quantity))</h5>
                        <a asp-action="Clear" class="text-danger text-decoration-none small fw-bold" onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                            <i class="fa-solid fa-trash-can me-2"></i>Xóa tất cả
                        </a>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="text-muted small text-uppercase">
                                <tr>
                                    <th class="border-0 px-0">Sản phẩm</th>
                                    <th class="border-0 text-center">Giá</th>
                                    <th class="border-0 text-center">Số lượng</th>
                                    <th class="border-0 text-end">Tổng</th>
                                    <th class="border-0"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="px-0 py-4" style="min-width: 300px;">
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(item.Photo) ? WebConfig.ImageServerUrl + "/images/products/nophoto.png" : $"{WebConfig.ImageServerUrl}/images/products/{item.Photo}")" 
                                                     class="rounded-3 shadow-sm me-3" width="70" height="70" style="object-fit: cover;">
                                                <div>
                                                    <h6 class="fw-bold mb-1">
                                                        <a href="@Url.Action("Detail", "Product", new { id = item.ProductID })" class="text-dark text-decoration-none">@item.ProductName</a>
                                                    </h6>
                                                    <span class="text-muted small">Đơn vị: @item.Unit</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-medium">@item.Price.ToString("N0") đ</td>
                                        <td class="text-center" style="width: 140px;">
                                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.ProductID" />
                                                <div class="input-group input-group-sm">
                                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn btn-outline-secondary border-0 bg-light rounded-pill px-2">-</button>
                                                    <input type="text" class="form-control text-center border-0 bg-light fw-bold" value="@item.Quantity" readonly style="width: 40px; background: transparent;">
                                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn btn-outline-secondary border-0 bg-light rounded-pill px-2">+</button>
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end fw-bold text-primary">@item.TotalPrice.ToString("N0") đ</td>
                                        <td class="text-end ps-4">
                                            <a asp-action="Remove" asp-route-id="@item.ProductID" class="btn btn-light btn-sm rounded-circle p-2 text-danger opacity-75">
                                                <i class="fa-solid fa-xmark"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="mt-4 border-top pt-4">
                        <a asp-controller="Product" asp-action="Index" class="text-primary text-decoration-none fw-bold">
                            <i class="fa-solid fa-arrow-left me-2"></i>Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card p-4 border-0 shadow-sm fade-in rounded-4">
                    <h5 class="fw-bold mb-4">Tổng kết đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>
                    <hr class="my-4">
                    <div class="d-flex justify-content-between mb-5">
                        <h5 class="fw-bold">Tổng cộng</h5>
                        <h5 class="fw-bold text-primary">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</h5>
                    </div>
                    
                    @if (Context.Session.GetString("CustomerEmail") != null)
                    {
                        <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary w-100 py-3 fs-5 rounded-pill shadow">
                            Tiến hành đặt hàng <i class="fa-solid fa-arrow-right ms-2"></i>
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning border-0 small mb-4 rounded-3">
                            <i class="fa-solid fa-circle-info me-2"></i>Vui lòng <a asp-controller="Account" asp-action="Login" class="fw-bold text-warning">đăng nhập</a> để đặt hàng.
                        </div>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100 py-3 rounded-pill">Đăng nhập để tiếp tục</a>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 150px; height: 150px;">
                    <i class="fa-solid fa-shopping-basket text-muted" style="font-size: 5rem;"></i>
                </div>
            </div>
            <h4 class="fw-bold mb-3">Giỏ hàng của bạn đang trống</h4>
            <p class="text-muted mb-4">Có vẻ như bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow">Mua sắm ngay</a>
        </div>
    }
</div>
