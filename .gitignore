## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build log files
*.log

# Visual Studio 2017 AutoGenerated files
Generated\ Files/

# Others
*.[Cc]ache
!*.[Cc]ache/
*[Vv]shost*
*[Vv]shost*.exe
*.bak
*.cache
*.pdb
*.sql
*.exe
*.dll
*.suo
*.user
*.userosscache
*.sln.docstates
*.pyc

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet 2.x
# **/packages/

# Microsoft Azure Build Output
csx/
*.cscfg
*.csdef

# Windows Image files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycled Menu File
Target.txt

# Windows temporary files
*~
~$*
