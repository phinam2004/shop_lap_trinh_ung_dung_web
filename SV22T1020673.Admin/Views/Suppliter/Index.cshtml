<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Danh sách nhà cung cấp</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f4f6f9;
        }

        .table th, .table td {
            vertical-align: middle;
            white-space: nowrap;
        }
    </style>
</head>
<body>

    <!-- ===== FULL WIDTH ===== -->
    <div class="container-fluid px-4 mt-4">

        <!-- ===== TITLE ===== -->
        <h3 class="mb-3">Danh sách nhà cung cấp</h3>

        <!-- ===== SEARCH + BUTTONS ===== -->
        <div class="row mb-3">
            <div class="col-lg-7 col-md-6">
                <input type="text" class="form-control"
                       placeholder="Tìm theo tên, tên giao dịch, email, số điện thoại, tỉnh/thành...">
            </div>

            <div class="col-lg-2 col-md-2">
                <button class="btn btn-primary w-100">
                    🔍 Search
                </button>
            </div>

            <div class="col-lg-2 col-md-2">
                <a href="/Suppliter/Create" class="btn btn-success w-100">
                    ➕ Create
                </a>
            </div>
        </div>

        <!-- ===== FOUND RESULT (CÁCH XA HƠN SEARCH) ===== -->
        <div class="row mb-4">
            <div class="col-12">
                <span class="text-muted">
                    Tìm thấy <b>3</b> dòng dữ liệu
                </span>
            </div>
        </div>

        <!-- ===== TABLE ===== -->
        <div class="card">
            <div class="card-body p-0 table-responsive">
                <table class="table table-bordered table-hover mb-0 w-100">
                    <thead class="table-light">
                        <tr>
                            <th>Tên nhà cung cấp</th>
                            <th>Tên giao dịch</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Địa chỉ</th>
                            <th>Tỉnh / Thành</th>
                            <th style="width:160px">Chức năng</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Công ty ABC</td>
                            <td>ABC Trading</td>
                            <td>contact@abc.com</td>
                            <td>0901234567</td>
                            <td>123 Trần Hưng Đạo</td>
                            <td>Hà Nội</td>
                            <td>
                                <a href="/Suppliter/Edit/1" class="btn btn-sm btn-warning">✏️ Edit</a>
                                <a href="/Suppliter/Delete/1"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Bạn có chắc muốn xóa?')">
                                    🗑️ Xóa
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td>Công ty XYZ</td>
                            <td>XYZ Group</td>
                            <td>support@xyz.vn</td>
                            <td>0912345678</td>
                            <td>45 Lê Lợi</td>
                            <td>TP. Hồ Chí Minh</td>
                            <td>
                                <a href="/Suppliter/Edit/2" class="btn btn-sm btn-warning">✏️ Edit</a>
                                <a href="/Suppliter/Delete/2" class="btn btn-sm btn-danger">🗑️ Xóa</a>
                            </td>
                        </tr>

                        <tr>
                            <td>Nhà cung cấp Minh Long</td>
                            <td>Minh Long Co.</td>
                            <td>minhlong@gmail.com</td>
                            <td>0987654321</td>
                            <td>88 Nguyễn Huệ</td>
                            <td>Đà Nẵng</td>
                            <td>
                                <a href="/Suppliter/Edit/3" class="btn btn-sm btn-warning">✏️ Edit</a>
                                <a href="/Suppliter/Delete/3" class="btn btn-sm btn-danger">🗑️ Xóa</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===== PAGINATION ===== -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled"><a class="page-link">«</a></li>
                <li class="page-item active"><a class="page-link">1</a></li>
                <li class="page-item"><a class="page-link">2</a></li>
                <li class="page-item"><a class="page-link">»</a></li>
            </ul>
        </nav>

    </div>

</body>
</html>
