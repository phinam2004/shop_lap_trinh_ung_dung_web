<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Danh sách mặt hàng</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f4f6f9;
        }

        .table th, .table td {
            vertical-align: middle;
            white-space: nowrap;
        }

        .item-name {
            max-width: 260px;
        }
    </style>
</head>
<body>

    <div class="container-fluid px-4 mt-4">

        <!-- TITLE -->
        <h3 class="mb-3">Danh sách mặt hàng</h3>

        <!-- FILTER / SEARCH -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">

                    <!-- Phân loại hàng -->
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label">Phân loại hàng</label>
                        <select class="form-select">
                            <option value="">-- Tất cả --</option>
                            <option>Đồ uống</option>
                            <option>Thực phẩm</option>
                            <option>Gia dụng</option>
                        </select>
                    </div>

                    <!-- Nhà cung cấp -->
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label">Nhà cung cấp</label>
                        <select class="form-select">
                            <option value="">-- Tất cả --</option>
                            <option>Công ty ABC</option>
                            <option>Công ty XYZ</option>
                        </select>
                    </div>

                    <!-- Khoảng giá -->
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label">Khoảng giá</label>
                        <div class="input-group">
                            <input type="number"
                                   class="form-control"
                                   placeholder="Từ"
                                   min="0">
                            <span class="input-group-text">-</span>
                            <input type="number"
                                   class="form-control"
                                   placeholder="Đến"
                                   min="0">
                        </div>
                    </div>


                    <!-- Tên mặt hàng -->
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label">Tên mặt hàng</label>
                        <input type="text"
                               class="form-control"
                               placeholder="Nhập tên mặt hàng">
                    </div>

                    <!-- BUTTONS -->
                    <div class="col-12 text-end mt-3">
                        <button class="btn btn-primary me-2">
                            🔍 Tìm kiếm
                        </button>
                        <button class="btn btn-secondary">
                            ❌ Xóa lọc
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <!-- RESULT COUNT -->
        <div class="mb-3">
            <span class="text-muted">
                Tìm thấy <b>3</b> mặt hàng
            </span>
        </div>

        <!-- TABLE -->
        <div class="card">
            <div class="card-body p-0 table-responsive">
                <table class="table table-bordered table-hover mb-0 w-100">
                    <thead class="table-light">
                        <tr class="text-center">
                            <th>Tên hàng</th>
                            <th style="width:140px">Đơn vị tính</th>
                            <th style="width:160px">Giá</th>
                            <th style="width:120px">Ngừng bán</th>
                            <th style="width:160px">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        <!-- DỮ LIỆU DEMO -->
                        <tr>
                            <td class="item-name text-truncate">
                                Nước ngọt Coca Cola lon 330ml
                            </td>
                            <td class="text-center">Lon</td>
                            <td class="text-end">12.000 đ</td>
                            <td class="text-center">
                                <span class="badge bg-success">Đang bán</span>
                            </td>
                            <td class="text-center">
                                <a href="/Item/Edit/1" class="btn btn-sm btn-warning">✏️ Sửa</a>
                                <a href="/Item/Delete/1" class="btn btn-sm btn-danger">🗑️ Xóa</a>
                            </td>
                        </tr>

                        <tr>
                            <td class="item-name text-truncate">
                                Gạo ST25 túi 5kg
                            </td>
                            <td class="text-center">Túi</td>
                            <td class="text-end">135.000 đ</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">Ngừng bán</span>
                            </td>
                            <td class="text-center">
                                <a href="/Item/Edit/2" class="btn btn-sm btn-warning">✏️ Sửa</a>
                                <a href="/Item/Delete/2" class="btn btn-sm btn-danger">🗑️ Xóa</a>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </div>

        <!-- PAGINATION -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link">«</a>
                </li>
                <li class="page-item active">
                    <a class="page-link">1</a>
                </li>
                <li class="page-item">
                    <a class="page-link">2</a>
                </li>
                <li class="page-item">
                    <a class="page-link">»</a>
                </li>
            </ul>
        </nav>

    </div>

</body>
</html>
