@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-primary card-outline shadow-sm mt-4">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="bi bi-shield-lock me-2 text-primary"></i>
                    Đổi mật khẩu tài khoản
                </h5>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @ViewBag.Message
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <ul class="mb-0 list-unstyled">
                            @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@modelError.ErrorMessage</li>
                            }
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form action="~/Account/ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-muted text-uppercase mb-2">Mật khẩu hiện tại</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-unlock text-muted"></i>
                            </span>
                            <input type="password" name="oldPassword" class="form-control border-start-0" 
                                   placeholder="Nhập mật khẩu cũ của bạn" required autofocus />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-muted text-uppercase mb-2">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input type="password" name="newPassword" class="form-control border-start-0" 
                                   placeholder="Ít nhất 8 ký tự, chữ hoa, thường, số, ký tự đặc biệt" required />
                        </div>
                        <div class="mt-2 text-muted small">
                            <i class="bi bi-info-circle me-1"></i>
                            Yêu cầu: Ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt.
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-semibold small text-muted text-uppercase mb-2">Xác nhận mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-check-double text-muted"></i>
                            </span>
                            <input type="password" name="confirmPassword" class="form-control border-start-0" 
                                   placeholder="Nhập lại mật khẩu mới để xác nhận" required />
                        </div>
                    </div>

                    <div class="d-grid gap-3 pt-3 border-top">
                        <button type="submit" class="btn btn-primary py-2 fw-bold shadow-sm">
                            <i class="bi bi-key-fill me-2"></i>Cập nhật mật khẩu ngay
                        </button>
                        <a href="~/" class="btn btn-link text-decoration-none text-muted">
                            Hủy bỏ và quay lại trang chủ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
