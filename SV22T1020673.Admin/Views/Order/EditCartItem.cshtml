@model SV22T1020673.Models.Sales.CartItem
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">
        Cập nhật chi tiết đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <form id="formUpdateCartItem" action="~/Order/UpdateCartItem" method="post" class="container-fluid">
        <input type="hidden" name="productId" value="@Model.ProductID" />
        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Mặt hàng
                    </label>
                    <div class="col-sm-8">
                        <input type="text"
                               class="form-control-plaintext fw-bold text-primary"
                               value="@Model.ProductName"
                               readonly>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Số lượng
                    </label>
                    <div class="col-sm-5">
                        <input type="number"
                               name="quantity"
                               class="form-control text-end"
                               min="1"
                               value="@Model.Quantity">
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Đơn giá
                    </label>
                    <div class="col-sm-5">
                        <input type="text"
                               name="salePrice"
                               class="form-control text-end money-input"
                               value="@Model.SalePrice.ToString("N0")">
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-end">                
                <img src="@(string.IsNullOrEmpty(Model.Photo) ? Url.Content("~/images/products/demo.png") : Url.Content($"~/images/products/{Model.Photo}"))"
                     alt="@Model.ProductName"
                     class="img-thumbnail"
                     style="max-height:180px">
            </div>
        </div>
    </form>
</div>

<div class="modal-footer">
    <button type="submit" form="formUpdateCartItem" class="btn btn-primary">
        Cập nhật
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>

