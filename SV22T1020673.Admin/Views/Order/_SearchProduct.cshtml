@model SV22T1020673.Models.Common.PagedResult<SV22T1020673.Models.Catalog.Product>
@{
    Layout = null;
}

<!-- Danh sách mặt hàng -->
@if (Model.DataItems != null && Model.DataItems.Count > 0)
{
    @foreach (var item in Model.DataItems)
    {
        <form action="~/Order/AddCartItem" method="post" class="form-add-to-cart border rounded p-2 mb-2">
            <input type="hidden" name="ProductID" value="@item.ProductID" />
            <input type="hidden" name="ProductName" value="@item.ProductName" />
            <input type="hidden" name="Unit" value="@item.Unit" />
            <input type="hidden" name="Photo" value="@item.Photo" />
            
            <strong>@item.ProductName</strong>

            <div class="row mt-2">
                <div class="col-4">
                    <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/demo.png") : Url.Content($"~/images/products/{item.Photo}"))"
                         class="img-fluid border" style="max-height:100px" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0">Giá</label>
                            <input class="form-control form-control-sm money-input"
                                   name="SalePrice"
                                   value="@item.Price.ToString("N0")" />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0">SL</label>
                            <input type="number"
                                   name="Quantity"
                                   min="1"
                                   value="1"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }

    @if (Model.PageCount > 1)
    {
        <div class="card-footer px-0 pb-0 bg-transparent border-0">
            <ul class="pagination pagination-sm justify-content-between mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" 
                       onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @(Model.Page - 1))">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link text-dark">Trang @Model.Page/@Model.PageCount</span>
                </li>
                <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" 
                       onclick="paginationSearch(event, document.getElementById('formSearchProduct'), @(Model.Page + 1))">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
}
else
{
    <div class="alert alert-warning text-center">
        Không tìm thấy mặt hàng nào
    </div>
}
