@using SV22T1020673.Models.Common
@using SV22T1020673.Models.Sales
@model DashboardViewModel
@{
    ViewBag.Title = "Bảng điều khiển";
}

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@Model.TotalRevenueToday.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng mới</h6>
                        <h3 class="mb-0">@Model.NewOrderCount</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@Model.TotalCustomerCount</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@Model.TotalProductCount</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body" style="min-height: 200px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.TopProducts)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            @item.ProductName
                            <span class="badge bg-success">@item.Quantity</span>
                        </li>
                    }
                    @if (!Model.TopProducts.Any())
                    {
                        <li class="list-group-item text-muted">Chưa có dữ liệu bán hàng.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th style="width: 40px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PendingOrders)
                        {
                            <tr>
                                <td>
                                    <a href="~/Order/Detail/@item.OrderID" class="text-decoration-none">
                                        #@item.OrderID.ToString("D5")
                                    </a>
                                </td>
                                <td>@item.CustomerName</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">@item.SumOfPrice.ToString("N0") đ</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case OrderStatusEnum.New:
                                            <span class="badge bg-danger">@item.Status.GetDescription()</span>
                                            break;
                                        case OrderStatusEnum.Accepted:
                                            <span class="badge bg-warning text-dark">@item.Status.GetDescription()</span>
                                            break;
                                        default:
                                            <span class="badge bg-info">@item.Status.GetDescription()</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary" title="Chi tiết đơn hàng">
                                        <i class="bi bi-receipt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.PendingOrders.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">Không có đơn hàng nào cần xử lý.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('revenueChart');
            if (!ctx) return;

            if (typeof Chart === 'undefined') {
                console.error('Chart.js không được tải! Vui lòng kiểm tra kết nối internet hoặc đường dẫn thư viện.');
                ctx.parentElement.innerHTML = '<div class="text-center p-4 text-muted"><i class="bi bi-exclamation-triangle fs-1"></i><p>Không thể tải thư viện biểu đồ.</p></div>';
                return;
            }

            const monthlyData = @Html.Raw(Json.Serialize(Model.MonthlyRevenues));

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: monthlyData.map(r => `Tháng ${r.month || r.Month}/${r.year || r.Year}`),
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: monthlyData.map(r => r.total || r.Total || 0),
                        backgroundColor: 'rgba(13,110,253,0.7)',
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.raw.toLocaleString() + ' VNĐ';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}